# ─────────────────────────────────────────────────────────
# HeyPico Maps — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Google Maps ───────────────────────────────────────────
# Get your key at: https://console.cloud.google.com/
# Required APIs to enable:
#   - Maps JavaScript API
#   - Places API
#   - Directions API (optional, for directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Ollama LLM ────────────────────────────────────────────
# Default: mistral (best balance of speed + accuracy)
# Alternatives: llama3, gemma2, phi3, qwen2
OLLAMA_MODEL=mistral
