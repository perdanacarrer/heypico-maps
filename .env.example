# ─────────────────────────────────────────────────────────────────
# HeyPico Maps — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env:
#   cp .env.example .env
#
# ✅ NO Google Maps API key required!
#    This project uses OpenStreetMap (free, no signup, no credit card)
# ─────────────────────────────────────────────────────────────────

# LLM model to use via Ollama
# Options: mistral (default), llama3, gemma2, phi3, qwen2
# mistral is recommended: best instruction-following + JSON output at 7B
OLLAMA_MODEL=mistral
